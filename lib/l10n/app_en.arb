    "description": "App name shown in the OS task switcher (not the app bar, which shows the user-editable title)."
  },
  "settingsTooltip": "Settings",
  "@settingsTooltip": {
    "description": "Tooltip for the settings (cog) button in the home screen's app bar."
  },
  "todayLabel": "Today",
  "@todayLabel": {
    "description": "Label for the segmented button option showing today's tasks."
  },
  "tomorrowLabel": "Tomorrow",
  "@tomorrowLabel": {
    "description": "Label for the segmented button option showing tomorrow's tasks."
  },
  "failedToLoadTasks": "Failed to load tasks: {error}",
  "@failedToLoadTasks": {
    "description": "Shown when fetching tasks from Google Calendar fails.",
    "placeholders": {
      "error": {"type": "String"}
    }
  },
  "nothingPlannedToday": "Nothing planned for today!",
  "@nothingPlannedToday": {
    "description": "Empty state shown when today has no tasks."
