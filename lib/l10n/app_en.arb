  "nothingPlannedTomorrow": "Nothing planned for tomorrow!",
  "@nothingPlannedTomorrow": {
    "description": "Empty state shown when tomorrow has no tasks."
  },
  "settingsTitle": "Settings",
  "@settingsTitle": {
    "description": "Title of the settings screen's app bar."
  },
  "appTitleSettingLabel": "App title",
  "@appTitleSettingLabel": {
    "description": "Label for the setting that edits the home screen's app bar title."
  },
  "signOut": "Sign out",
  "@signOut": {
    "description": "Sign-out action label."
  },
  "cancel": "Cancel",
  "@cancel": {
    "description": "Cancel button label in dialogs."
  },
  "save": "Save",
  "@save": {
    "description": "Save button label in dialogs."
  },
  "languageSettingLabel": "Language",
  "@languageSettingLabel": {
    "description": "Label for the language setting."
  },
  "chooseLanguage": "Choose language",
  "@chooseLanguage": {
    "description": "Title of the language picker dialog."
  },
  "signInFailed": "Sign-in failed: {error}",
  "@signInFailed": {
    "description": "Snackbar shown when Google sign-in fails.",
    "placeholders": {
      "error": {"type": "String"}
    }
  },
  "signInSubtitle": "Sign in with Google to see your day on the clock.",
  "@signInSubtitle": {
    "description": "Subtitle shown on the sign-in screen."
  },
  "signInButton": "Sign in with Google",
  "@signInButton": {
    "description": "Sign-in button label."
  },
  "signInError": "Sign-in error: {error}",
  "@signInError": {
    "description": "Shown when the auth state stream itself errors.",
    "placeholders": {
      "error": {"type": "String"}
    }
  }
